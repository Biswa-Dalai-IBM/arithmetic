<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1
          http://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>dist</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>arithmetic-${project.version}</baseDirectory>

    <fileSets>
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>${project.artifactId}-${project.version}.jar</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>${project.build.directory}/lib</directory>
            <outputDirectory>/lib</outputDirectory>
            <includes>
                <include>*.jar</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>run-claude.bat</include>
                <include>run-claude.sh</include>
                <include>run-openai.bat</include>
                <include>run-openai.sh</include>
                <include>run-llama.bat</include>
                <include>run-llama.sh</include>
                <include>build-arithmetic.bat</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>README.md</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/src/main/antlr4</directory>
            <outputDirectory>/grammar</outputDirectory>
            <includes>
                <include>**/*.g4</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/samples</directory>
            <outputDirectory>/samples</outputDirectory>
            <includes>
                <include>*.txt</include>
                <include>README.md</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>

